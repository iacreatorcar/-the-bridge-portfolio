---
const title = "The Bridge | Digital Systems Ecosystem";

const systems = [

{
title:"NauticGantt",
description:"Charter fleet management platform — real-time Gantt, maintenance tracking, bookings and supplier coordination.",
image:"/assets/images/nauticgantt.jpg",
link:"https://shipyard-flow.vercel.app"
},


{
title:"HotelFlow",
description:"Hospitality workflow platform for operational coordination.",
image:"/assets/images/hotelflow.jpg",
link:"https://hotelflow-manager.vercel.app"
},

{
title:"Mini Jira",
description:"Operational ticketing system for technical teams.",
image:"/assets/images/jira-demo.jpg",
link:"https://mini-jira-demo.vercel.app"
},

{
title:"CMS Governance Simulator",
description:"Interactive CMS publishing workflow simulator.",
image:"/assets/images/cms-quiz.jpg",
link:"https://iacreatorcar.github.io/cms-quiz/"
},

{
title:"Symphony Spa",
description:"Cruise UX concept for spa discovery and booking.",
image:"/assets/images/Symphony-Luxury.jpg",
link:"https://symphony-spa.vercel.app"
},

{
title:"Nexus XPanel",
description:"Control panel for onboard digital systems.",
image:"/assets/images/nexus.jpg",
link:"https://nexus-xpanel.vercel.app"
},

];
---

<html lang="en">

<head>

<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>{title}</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
(function(c,l,a,r,i,t,y){
c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
})(window, document, "clarity", "script", "vd3swciqr5");
</script>

<style>

/* GLOBAL */

body{
margin:0;
font-family:system-ui;
background:#0f172a;
color:white;
scroll-behavior:smooth;
}

/* NAVBAR */

nav{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:#020617;
position:sticky;
top:0;
z-index:100;
box-shadow:0 10px 30px rgba(0,0,0,.4);
}

.brand{
font-weight:700;
font-size:18px;
}

.bridge{
color:#facc15;
}

.nav-links{
display:flex;
gap:12px;
}

.nav-links a{
background:#1e293b;
padding:8px 16px;
border-radius:20px;
color:#e2e8f0;
text-decoration:none;
font-size:14px;
transition:.2s;
}

.nav-links a:hover{
background:#facc15;
color:#020617;
}

/* HERO */

.hero{
min-height:85vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
padding:40px;
background:linear-gradient(180deg,#0f172a,#1e293b);
}

.hero h1{
font-size:3rem;
margin-bottom:20px;
}

.hero p{
max-width:700px;
color:#cbd5e1;
}

/* BUTTON */

.button{
background:#facc15;
color:#020617;
padding:12px 22px;
border-radius:8px;
text-decoration:none;
font-weight:600;
}

/* SECTION */

section{
padding:90px 20px;
max-width:1100px;
margin:auto;
}

.section-title{
text-align:center;
font-size:2rem;
margin-bottom:50px;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
gap:25px;
}

/* CARDS */

.card{
background:#1e293b;
padding:15px;
border-radius:10px;
text-decoration:none;
color:white;
transition:.3s;
}

.card:hover{
transform:translateY(-6px);
}

.card img{
width: 100%;
  height: 160px;
  object-fit: cover;
  object-position: top;
  border-radius: 8px;
}

/* MAP */

#mapContainer{
height:500px;
border-radius:12px;
margin-top:40px;
}

/* TECHNICAL PORTFOLIO */

.portfolio-card{
display:grid;
grid-template-columns:1fr 1fr;
gap:30px;
align-items:center;
background:#1e293b;
padding:30px;
border-radius:12px;
}

.portfolio-card img{
width:100%;
border-radius:10px;
}

.portfolio-buttons{
margin-top:20px;
display:flex;
gap:16px;
align-items:center;
flex-wrap:wrap;
}

.button-outline{
border:2px solid #facc15;
padding:10px 20px;
border-radius:8px;
color:#facc15;
text-decoration:none;
}

/* FOOTER */

footer{
padding:60px;
text-align:center;
background:#020617;
color:#94a3b8;
}

@media(max-width:800px){

.portfolio-card{
grid-template-columns:1fr;
}

}

</style>

</head>

<body>

<nav>

<div class="brand">
Carmine D'Alise |
<span class="bridge">The Bridge</span>
</div>

<div class="nav-links">

<a href="#systems">Systems</a>
<a href="#destinations">Media</a>
<a href="#map">Map</a>
<a href="#technical">Portfolio</a>

</div>

</nav>

<section class="hero">

<h1>The Bridge</h1>

<p>
Digital Systems Ecosystem — Charter · Yacht · Cruise technology,
operational platforms and fleet management solutions.
</p>

<a class="button" href="#systems">Explore Systems</a>

</section>

<section id="systems">

<h2 class="section-title">Digital Systems</h2>

<div class="grid">

{systems.map(system => (

<a href={system.link} target="_blank" class="card">

<img src={system.image} alt={system.title}/>

<h4>{system.title}</h4>

<p>{system.description}</p>

</a>

))}

</div>

</section>

<section id="destinations">

<h2 class="section-title">Cruise Destination Media</h2>

<div class="grid">

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/DANi1zlzXtg"></iframe><h4>Palma</h4></div>

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/I6D_WXXDE0o"></iframe><h4>Rome</h4></div>

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/n6kDGHPseNc"></iframe><h4>Barcelona</h4></div>

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/XkoI9IjtZJQ"></iframe><h4>Split</h4></div>

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/Wq83nqRWJKI"></iframe><h4>Dubrovnik</h4></div>

<div class="card"><iframe width="100%" height="160" src="https://www.youtube.com/embed/k0iDrOoFsoc"></iframe><h4>Tarragona</h4></div>

</div>

</section>

<section id="map">

<h2 class="section-title">Mediterranean Cruise Map</h2>

<div id="mapContainer"></div>

</section>

<section id="technical">

<h2 class="section-title">Technical Portfolio</h2>

<div class="portfolio-card">

<img src="/assets/images/technical-portfolio.jpg">

<div>

<h3>Technical Systems Portfolio</h3>

<p>
Download the full engineering portfolio documenting AV systems,
network infrastructure and cruise digital platforms.
</p>

<div class="portfolio-buttons">

<a href="/docs/carmine-dalise-technical-portfolio.pdf" class="button" target="_blank">
Download PDF
</a>

<a href="https://www.canva.com/design/DAGFNejoyL4/5MlHThgTRUWJmlbR2o-33g/edit" class="button-outline" target="_blank">
View Portfolio
</a>

</div>

</div>

</div>

</section>

<footer>

<p>© Carmine D'Alise</p>

<p>The Bridge — Digital Systems Ecosystem</p>

</footer>

<script>

document.addEventListener("DOMContentLoaded",()=>{

const map=L.map('mapContainer').setView([41.5,12.5],4);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{maxZoom:18}).addTo(map);

const ports=[
[41.3851,2.1734],
[39.5696,2.6502],
[41.9028,12.4964],
[43.5081,16.4402],
[42.6507,18.0944],
[37.9838,23.7275]
];

ports.forEach(coords=>{
L.marker(coords).addTo(map);
});

});

</script>

</body>

</html>